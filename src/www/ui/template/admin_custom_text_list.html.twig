{% extends "include/base.html.twig" %}

{% block styles %}
  {{ parent() }}
  <style>
    .phrase-badge-add  { background-color: #28a745; color: #fff; }
    .phrase-badge-rm   { background-color: #dc3545; color: #fff; }
  </style>
{% endblock %}

{% block content %}

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="mb-0">{{ 'Custom Text Phrases'|trans }}</h4>
  <a href="?mod={{ addModuleName }}&edit=0" class="btn btn-success btn-sm">
    <i class="bi bi-plus-circle"></i> {{ 'Add New'|trans }}
  </a>
</div>

<div class="card shadow-sm">
  <div class="card-body p-2">
    <table class="semibordered" id="customPhrasesTable" width="100%" cellpadding="0">
      <thead>
        <tr>
          <th>{{ "Edit"|trans }}</th>
          <th>{{ "Licenses"|trans }}</th>
          <th>{{ "Text"|trans }}</th>
          <th>{{ "Acknowledgement"|trans }}</th>
          <th>{{ "Comments"|trans }}</th>
          <th>{{ "Created By"|trans }}</th>
          <th>{{ "Created Date"|trans }}</th>
          <th>{{ "Active"|trans }}</th>
          <th>{{ "Actions"|trans }}</th>
        </tr>
      </thead>
    </table>
  </div>
</div>

{% endblock %}

{% block foot %}
  {{ parent() }}
  <script src="scripts/jquery.dataTables.min.js" type="text/javascript"></script>
  <script src="scripts/jquery.dataTables.select.js" type="text/javascript"></script>
  <script type="text/javascript">
    $(document).ready(function () {
      $('#customPhrasesTable').DataTable({
        "processing": true,
        "serverSide": true,
        "ajax": { "url": "?mod=admin_custom_text_list&action=fetchData", "type": "GET" },
        "columns": [
          { "data": 0, "orderable": false },
          { "data": 1, "orderable": false },
          { "data": 2, "orderable": false },
          { "data": 3, "orderable": false },
          { "data": 4, "orderable": false },
          { "data": 5, "orderable": false },
          { "data": 6, "orderable": true  },
          { "data": 7, "orderable": false },
          { "data": 8, "orderable": false }
        ],
        "columnDefs": [
          { "targets": [0, 6, 7, 8], "className": "text-center" },
          { "targets": [0, 7, 8],    "searchable": false, "orderable": false },
          { "targets": [1, 2, 3, 4, 5], "searchable": true,  "orderable": false },
          { "targets": [6],          "searchable": false, "orderable": true  }
        ],
        "order": [[ 6, "desc" ]],
        "pageLength": 20,
        "stateSave": true,
        "dom": '<"top"lf>rt<"bottom"ip><"clear">',
        "initComplete": function() {
          var $toolbar = $('<div class="btn-group btn-group-sm mr-2">' +
            '<a href="?mod=admin_custom_text_to_csv"  class="btn btn-outline-secondary">{{ "Export CSV"|trans }}</a>' +
            '<a href="?mod=admin_custom_text_to_json" class="btn btn-outline-secondary">{{ "Export JSON"|trans }}</a>' +
            '<a href="?mod=admin_custom_text_import"  class="btn btn-outline-secondary">{{ "Import"|trans }}</a>' +
            '</div>');
          $('.dataTables_filter').prepend($toolbar);
        }
      });

      $(document).on('click', '.custom-text-delete', function () {
        var phraseId = parseInt($(this).data('phrase-id'), 10);
        if (confirm("{{ 'Are you sure you want to delete this custom text? This action cannot be undone.'|trans }}")) {
          $.ajax({
            url: "?mod=admin_custom_text_list&action=delete",
            type: "POST",
            data: { id: phraseId },
            dataType: "json",
            success: function (data) {
              if (data.error) { alert("Error: " + data.error); }
              else {
                alert(data.message || "{{ 'Custom text deleted successfully!'|trans }}");
                $('#customPhrasesTable').DataTable().ajax.reload(null, false);
              }
            },
            error: function (xhr, status, error) { alert("{{ 'Error deleting text:'|trans }} " + error); }
          });
        }
      });

      $(document).on('change', '.phrase-status-toggle', function () {
        var phraseId     = parseInt($(this).data('phrase-id'), 10);
        var currentStatus = parseInt($(this).data('current-status'), 10);
        $.ajax({
          url: "?mod=admin_custom_text_list&action=toggle",
          type: "POST",
          data: { id: phraseId, status: currentStatus ? 0 : 1 },
          dataType: "json",
          success: function (data) {
            if (data.error) { alert("Error: " + data.error); }
            else { $('#customPhrasesTable').DataTable().ajax.reload(null, false); }
          },
          error: function (xhr, status, error) { alert("{{ 'Error toggling status:'|trans }} " + error); }
        });
      });
    });
  </script>
{% endblock %}
