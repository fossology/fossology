{% extends "include/base.html.twig" %}

{% block content %}

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="mb-0">{{ 'Import Custom Text Phrases'|trans }}</h4>
  <a href="{{ baseUrl }}/?mod=admin_custom_text_list" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left"></i> {{ 'Back to List'|trans }}
  </a>
</div>

{% if message is defined and message %}
  <div class="alert alert-info alert-dismissible fade show" role="alert">
    {{ message|e }}
    <button type="button" class="close" data-dismiss="alert" aria-label="{{ 'Close'|trans }}">
      <span aria-hidden="true">&times;</span>
    </button>
  </div>
{% endif %}

<div class="row">
  <div class="col-md-6">
    <div class="card shadow-sm mb-4">
      <div class="card-header"><strong>{{ 'Upload File'|trans }}</strong></div>
      <div class="card-body">
        <form enctype="multipart/form-data" method="post">
          <div class="form-group">
            <label>{{ 'Select file to upload'|trans }}</label>
            <div class="custom-file">
              <input type="file" class="custom-file-input" id="fileInput"
                     name="file_input" accept=".csv,.json" required>
              <label class="custom-file-label" for="fileInput">{{ 'Choose file…'|trans }}</label>
            </div>
            <small class="form-text text-muted">{{ 'Supported formats: CSV, JSON'|trans }}</small>
          </div>

          <div class="form-row">
            <div class="form-group col-md-6">
              <label for="delimiterSelect">{{ 'CSV Delimiter'|trans }}</label>
              <select name="delimiter" id="delimiterSelect" class="form-control">
                <option value=",">, ({{ 'comma'|trans }})</option>
                <option value=";">; ({{ 'semicolon'|trans }})</option>
                <option value="\t">\t ({{ 'tab'|trans }})</option>
              </select>
            </div>
            <div class="form-group col-md-6">
              <label for="enclosureSelect">{{ 'CSV Enclosure'|trans }}</label>
              <select name="enclosure" id="enclosureSelect" class="form-control">
                <option value='"'>" ({{ 'double quote'|trans }})</option>
                <option value="'">' ({{ 'single quote'|trans }})</option>
              </select>
            </div>
          </div>

          <button type="submit" class="btn btn-primary">
            <i class="bi bi-upload"></i> {{ 'Upload'|trans }}
          </button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card shadow-sm mb-4">
      <div class="card-header"><strong>{{ 'File Format'|trans }}</strong></div>
      <div class="card-body">
        <h6>{{ 'CSV Format'|trans }}</h6>
        <p class="text-muted small mb-1">{{ 'Required columns:'|trans }} <code>Text</code></p>
        <p class="text-muted small">{{ 'Optional:'|trans }}
          <code>Acknowledgement</code>, <code>Comments</code>, <code>Is Active</code>,
          <code>Created By</code>, <code>Group</code>, <code>Associated Licenses</code>
        </p>

        <h6 class="mt-3">{{ 'JSON Format'|trans }}</h6>
        <p class="text-muted small">{{ 'Array of objects with fields:'|trans }}
          <code>text</code> ({{ 'required'|trans }}),
          <code>acknowledgement</code>, <code>comments</code>, <code>is_active</code>,
          <code>created_by</code>, <code>group</code>, <code>associated_licenses</code>
        </p>
      </div>
    </div>
  </div>
</div>

{% endblock %}

{% block foot %}
  {{ parent() }}
  <script type="text/javascript">
    /* Update custom-file label with selected filename */
    $('#fileInput').on('change', function() {
      var name = $(this).val().split('\\').pop() || $(this).val().split('/').pop();
      $(this).siblings('.custom-file-label').text(name || '{{ "Choose file…"|trans }}');
    });
  </script>
{% endblock %}
