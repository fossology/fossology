function refreshKotobaHistory(callbacksuccess) {
  $.ajax({
    url: "{{ baseuri }}?mod=kotoba-history&upload={{ uploadId }}&item={{ itemId }}{{ kotobaHistoryOptions }}",
    success: function(data) {
      $('#kotobaHistoryTable').html(data);
      callbacksuccess(data);
    }
  });
}

